{
  "kind": "collectionType",
  "collectionName": "portofolios",
  "info": {
    "singularName": "portofolio",
    "pluralName": "portofolios",
    "displayName": "Portofolio"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Title": {
      "type": "string",
      "required": true
    },
    "Type": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "Environmental",
        "Electrical"
      ]
    },
    "isFeatured": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "pinnedOrder": {
      "type": "integer",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "isFeatured"
            },
            true
          ]
        }
      },
      "default": 0,
      "unique": true
    },
    "Description": {
      "type": "blocks",
      "required": true
    },
    "Image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "videos"
      ]
    },
    "Location": {
      "type": "component",
      "component": "component-block.location-block",
      "repeatable": false,
      "required": true
    },
    "Timestamp": {
      "type": "component",
      "component": "component-block.project-period",
      "repeatable": false,
      "required": true
    }
  }
}
