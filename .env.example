# ============================================
# DATABASE CONFIGURATION - IoT Sensors Data
# ============================================
DB_USER=admin
DB_PASS=adminpassword
DB_IOT_NAME=sensordata

# ============================================
# DATABASE CONFIGURATION - Strapi CMS
# ============================================
DB_STRAPI_NAME=strapi_data
DB_STRAPI_USER=strapi_user
DB_STRAPI_PASS=strapi_password

# ============================================
# STRAPI CONFIGURATION
# ============================================
STRAPI_HOST=0.0.0.0
STRAPI_PORT=1337
STRAPI_NODE_ENV=development

# Strapi Secrets (generated by Strapi)
STRAPI_APP_KEYS=your_app_keys_here
STRAPI_API_TOKEN_SALT=your_api_token_salt_here
STRAPI_ADMIN_JWT_SECRET=your_admin_jwt_secret_here
STRAPI_JWT_SECRET=your_jwt_secret_here
STRAPI_TRANSFER_TOKEN_SALT=your_transfer_token_salt_here
STRAPI_ENCRYPTION_KEY=your_encryption_key_here

# ============================================
# IMAGEKIT CONFIGURATION
# ============================================
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# ============================================
# BACKEND CONFIGURATION
# ============================================
BACKEND_SECRET_KEY=your_backend_secret_key_here

# ============================================
# FRONTEND CONFIGURATION
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_STRAPI_API_URL=http://localhost:1337
